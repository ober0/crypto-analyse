enum UsageType {
  TickerProcessing
  BotProcessing

  @@map("usage_type")
}

model Usage {
  id Int @id @default(autoincrement())

  prompt   Int
  response Int

  model Models

  tickerProcessing TickerProcessing?

  aiProcessing   AiProcessing? @relation(fields: [aiProcessingId], references: [id], onDelete: SetNull)
  aiProcessingId Int?

  type UsageType

  createdAt DateTime @default(now())

  @@map("usage")
}
