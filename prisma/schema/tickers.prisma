model Tickers {
  id Int @id @default(autoincrement())

  name String

  aiProcessing     AiProcessing[]
  tickerProcessing TickerProcessing[]
  Trade            Trade[]

  @@map("tickers")
}

enum TimeframeEnum {
  OneDay
  OneWeek

  @@map("timeframe_enum")
}

enum DirectionEnum {
  Short
  Long
  Nothing

  @@map("direction_enum")
}

enum Models {
  Gpt5
  Deepseek4Flash
  Llama4
}

model TickerProcessing {
  id        Int           @id @default(autoincrement())
  ticker    Tickers       @relation(fields: [tickersId], references: [id])
  tickersId Int
  timeframe TimeframeEnum

  model Models

  direction DirectionEnum

  leverage   Float?
  stopLoss   Float?
  takeProfit Float?

  currentPrice   Float
  predictedPrice Float
  realPrice      Float?

  difference           Float?
  unrealizedDifference Float?
  pnl                  Float?
  unrealizedPnl        Float?
  isPredictAchieved    Boolean?

  usage   Usage @relation(fields: [usageId], references: [id])
  usageId Int   @unique

  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([isClosed])
  @@map("ticker_processing")
}
